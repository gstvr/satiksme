<!doctype html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport"
          content="width=device-width, user-scalable=no, initial-scale=1.0, maximum-scale=1.0, minimum-scale=1.0">
    <meta http-equiv="X-UA-Compatible" content="ie=edge">
    <title>Departures</title>
    <style>
        html {
            box-sizing: border-box;
            font-size: 16px;
        }

        *, *:before, *:after {
            box-sizing: inherit;
        }

        body {
            font-family: -apple-system, BlinkMacSystemFont, Segoe UI, Roboto, Helvetica, Arial, sans-serif, Apple Color Emoji, Segoe UI Emoji, Segoe UI Symbol;
            margin: 0;
            padding: 0;
        }

        @media (prefers-color-scheme: dark) {
            body {
                color: #f4f4f4;
                background: #1c1c1e;
            }
        }

        .container {
            max-width: 400px;
            margin: 0 auto;
            padding: 1rem;
        }

        section {
            margin-bottom: 1rem;
        }

        a {
            text-decoration: none;
            color: #008cff;
        }

        a.active {
            text-decoration: underline;
        }

        .stop {
            margin-bottom: 1rem;
        }

        .stop .name {
            margin-bottom: 0.25rem;
        }


        .departure {
            border: 1px solid #e5e5e5;;
            padding: 0.25rem;
            margin-bottom: 0.25rem;
            border-radius: 6px;
            box-shadow:  rgba(0, 0, 0, 0.05) 0 1px 2px 0;
        }

        @media (prefers-color-scheme: dark) {
            .departure {
                border-color: #363636;
                background: #181818;
            }
        }

        .route {
            padding: 0.25rem;
            text-align: center;
            display: inline-block;
            color: #fff;
            border-radius: 5px;
            min-width: 1.75rem;
            margin-right: 0.125rem;
        }

        .route.route-tram {
            background: #FF000C;
        }

        .route.route-trol {
            background: #009DE0;
        }

        .route.route-bus {
            background: #F4B427;
        }

        .grid {
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

        svg {
            width: 1rem;
            height: .75rem;
            line-height: 1;
            fill: currentColor;
        }
    </style>
</head>
<body>
<div class="container">
    <section>
        Board:
        {{ range $i, $board := .Boards }}
            <a href="/{{ $board.Slug }}"
               class="{{ if eq $board.Slug $.CurrentBoardSlug }}active{{ end }}">
                {{- $board.Name -}}
            </a>
        {{ end }}
    </section>

    <section>
        {{ range $stop := .Stops }}
            <div class="stop">
                <div class="name">{{ $stop.Name }}</div>

                {{ range $i, $departure := $stop.Departures }}
                    <div class="departure">
                        <div class="grid">
                            <div>
                                <a href="https://gsvalbe.id.lv/pieturas/karte.html?vid=rs_{{ $departure.VehicleID }}"
                                   target="_blank" rel="noreferrer"
                                   class="route route-{{ $departure.Line.VehicleType }}">
                                    {{ $departure.Line.Number }}
                                </a>
                                {{ $departure.Destination }}
                            </div>
                            <div>
                                {{ if $departure.IsAccessibleTram }}
                                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 512 512">
                                        <!--!Font Awesome Free 6.7.2 by @fontawesome - https://fontawesome.com License - https://fontawesome.com/license/free Copyright 2025 Fonticons, Inc.-->
                                        <path d="M192 96a48 48 0 1 0 0-96 48 48 0 1 0 0 96zM120.5 247.2c12.4-4.7 18.7-18.5 14-30.9s-18.5-18.7-30.9-14C43.1 225.1 0 283.5 0 352c0 88.4 71.6 160 160 160c61.2 0 114.3-34.3 141.2-84.7c6.2-11.7 1.8-26.2-9.9-32.5s-26.2-1.8-32.5 9.9C240 440 202.8 464 160 464C98.1 464 48 413.9 48 352c0-47.9 30.1-88.8 72.5-104.8zM259.8 176l-1.9-9.7c-4.5-22.3-24-38.3-46.8-38.3c-30.1 0-52.7 27.5-46.8 57l23.1 115.5c6 29.9 32.2 51.4 62.8 51.4l5.1 0c.4 0 .8 0 1.3 0l94.1 0c6.7 0 12.6 4.1 15 10.4L402 459.2c6 16.1 23.8 24.6 40.1 19.1l48-16c16.8-5.6 25.8-23.7 20.2-40.5s-23.7-25.8-40.5-20.2l-18.7 6.2-25.5-68c-11.7-31.2-41.6-51.9-74.9-51.9l-68.5 0-9.6-48 63.4 0c17.7 0 32-14.3 32-32s-14.3-32-32-32l-76.2 0z"/>
                                    </svg>
                                {{ end }}
                                {{ if $departure.IsElectricBus }}
                                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 512 512">
                                        <!--!Font Awesome Free 6.7.2 by @fontawesome - https://fontawesome.com License - https://fontawesome.com/license/free Copyright 2025 Fonticons, Inc.-->
                                        <path d="M272 96c-78.6 0-145.1 51.5-167.7 122.5c33.6-17 71.5-26.5 111.7-26.5l88 0c8.8 0 16 7.2 16 16s-7.2 16-16 16l-16 0-72 0s0 0 0 0c-16.6 0-32.7 1.9-48.3 5.4c-25.9 5.9-49.9 16.4-71.4 30.7c0 0 0 0 0 0C38.3 298.8 0 364.9 0 440l0 16c0 13.3 10.7 24 24 24s24-10.7 24-24l0-16c0-48.7 20.7-92.5 53.8-123.2C121.6 392.3 190.3 448 272 448l1 0c132.1-.7 239-130.9 239-291.4c0-42.6-7.5-83.1-21.1-119.6c-2.6-6.9-12.7-6.6-16.2-.1C455.9 72.1 418.7 96 376 96L272 96z"/>
                                    </svg>
                                {{ end }}

                                {{ $departure.RelativeDeparture $.Now }}
                                ({{ $departure.DepartsAt.Format "15:04" }})
                            </div>
                        </div>
                    </div>
                {{ end }}
            </div>
        {{ end }}
    </section>

    <section>
        <a href="https://gsvalbe.id.lv/pieturas/karte.html" target="_blank" rel="noreferrer">
            Map
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 512 512">
                <!--!Font Awesome Free 6.7.1 by @fontawesome - https://fontawesome.com License - https://fontawesome.com/license/free Copyright 2024 Fonticons, Inc.-->
                <path d="M320 0c-17.7 0-32 14.3-32 32s14.3 32 32 32l82.7 0L201.4 265.4c-12.5 12.5-12.5 32.8 0 45.3s32.8 12.5 45.3 0L448 109.3l0 82.7c0 17.7 14.3 32 32 32s32-14.3 32-32l0-160c0-17.7-14.3-32-32-32L320 0zM80 32C35.8 32 0 67.8 0 112L0 432c0 44.2 35.8 80 80 80l320 0c44.2 0 80-35.8 80-80l0-112c0-17.7-14.3-32-32-32s-32 14.3-32 32l0 112c0 8.8-7.2 16-16 16L80 448c-8.8 0-16-7.2-16-16l0-320c0-8.8 7.2-16 16-16l112 0c17.7 0 32-14.3 32-32s-14.3-32-32-32L80 32z"/>
            </svg>
        </a>
    </section>
</div>
</body>
</html>
